# === Project Root ===
# Absolute path to the BlackBox project root.
# Auto-detected if unset: walks up from Orchestrator/utils/paths.py looking for
# CLAUDE.md + Orchestrator/ sentinels. Raises RuntimeError if neither resolves.
# Set explicitly in production (recommended) for reliability across install layouts.
# BLACKBOX_ROOT=/path/to/your/blackbox_poc

# AI BlackBox Flight Recorder - API Keys Configuration
# Copy this file to .env and fill in your API keys

# OpenAI API Key (for GPT, DALL-E, Whisper, TTS)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Anthropic API Key (for Claude)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google API Key (for Gemini, Imagen, Veo, TTS)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_key_here
