<?xml version="1.0" encoding="utf-8"?>
<!--
  Drachtio Server Configuration for AI BlackBox Phone Integration

  Drachtio handles SIP signaling:
  - Receives INVITE from 3CX
  - Routes calls to FreeSwitch
  - Manages SIP dialogs
-->
<drachtio>
  <!-- Admin interface for our application -->
  <admin port="9022" secret="cymru">
    <request-handlers>
      <!-- Enable all request handlers -->
      <request-handler type="invite"/>
      <request-handler type="ack"/>
      <request-handler type="bye"/>
      <request-handler type="cancel"/>
      <request-handler type="info"/>
      <request-handler type="options"/>
      <request-handler type="register"/>
    </request-handlers>
  </admin>

  <!-- SIP transport configuration -->
  <sip>
    <contacts>
      <!-- Primary SIP contact (UDP) -->
      <contact>
        <protocol>udp</protocol>
        <address>0.0.0.0</address>
        <port>5060</port>
      </contact>

      <!-- TCP contact for TLS-capable endpoints -->
      <contact>
        <protocol>tcp</protocol>
        <address>0.0.0.0</address>
        <port>5060</port>
      </contact>
    </contacts>

    <!-- SIP timers (RFC 3261 defaults) -->
    <timers>
      <t1>500</t1>
      <t2>4000</t2>
      <t4>5000</t4>
    </timers>
  </sip>

  <!-- Logging configuration -->
  <logging>
    <loglevel>info</loglevel>
    <console-loglevel>info</console-loglevel>
  </logging>

  <!-- Monitoring and metrics -->
  <monitoring>
    <prometheus port="9090"/>
  </monitoring>

</drachtio>
