<?xml version="1.0" encoding="utf-8"?>
<!--
  FreeSwitch Dialplan for AI BlackBox Phone Integration

  Routes:
  - Inbound calls from 3CX to our app
  - Outbound calls via 3CX gateway
-->
<include>
  <context name="public">

    <!-- Inbound calls from 3CX -->
    <extension name="inbound-blackbox">
      <condition field="destination_number" expression=".*">
        <!-- Answer the call -->
        <action application="answer"/>

        <!-- Set variables for our app -->
        <action application="set" data="caller_id_number=${caller_id_number}"/>
        <action application="set" data="called_number=${destination_number}"/>

        <!-- Enable DTMF detection -->
        <action application="start_dtmf"/>

        <!-- Bridge audio to our WebSocket endpoint -->
        <!-- The actual WebSocket URL is set dynamically via ESL -->
        <action application="park"/>
      </condition>
    </extension>

    <!-- Outbound calls via 3CX gateway -->
    <extension name="outbound-3cx">
      <condition field="destination_number" expression="^(\+?[0-9]{10,15})$">
        <action application="set" data="effective_caller_id_number=${outbound_caller_id}"/>
        <action application="bridge" data="sofia/gateway/3cx/$1"/>
      </condition>
    </extension>

    <!-- Default action for unmatched calls -->
    <extension name="unmatched">
      <condition field="destination_number" expression=".*">
        <action application="log" data="WARNING Unmatched call to ${destination_number}"/>
        <action application="hangup" data="UNALLOCATED_NUMBER"/>
      </condition>
    </extension>

  </context>

  <!-- Internal context for testing -->
  <context name="default">

    <!-- Echo test -->
    <extension name="echo">
      <condition field="destination_number" expression="^9196$">
        <action application="answer"/>
        <action application="echo"/>
      </condition>
    </extension>

    <!-- Tone test -->
    <extension name="tone">
      <condition field="destination_number" expression="^9197$">
        <action application="answer"/>
        <action application="playback" data="tone_stream://%(1000,0,350,440)"/>
      </condition>
    </extension>

    <!-- DTMF test -->
    <extension name="dtmf-test">
      <condition field="destination_number" expression="^9198$">
        <action application="answer"/>
        <action application="start_dtmf"/>
        <action application="playback" data="silence_stream://5000"/>
        <action application="hangup"/>
      </condition>
    </extension>

  </context>
</include>
