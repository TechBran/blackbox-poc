# AI BlackBox Phone Integration - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# 3CX Cloud PBX Configuration
# =============================================================================

# Your 3CX URL (e.g., yourcompany.3cx.us)
PBX_3CX_URL=

# Extension number for the AI BlackBox line
PBX_3CX_EXTENSION=

# Extension password (from 3CX management console)
PBX_3CX_PASSWORD=

# DID number assigned to this extension (with country code)
PBX_3CX_DID=+15551234567

# Caller ID for outbound calls
PBX_OUTBOUND_CALLER_ID=+15551234567

# =============================================================================
# Drachtio Configuration
# =============================================================================

# Secret for Drachtio admin connection
DRACHTIO_SECRET=cymru

# =============================================================================
# FreeSwitch Configuration
# =============================================================================

# ESL password
ESL_PASSWORD=ClueCon

# =============================================================================
# Network Configuration
# =============================================================================

# Host IP address (for SIP/RTP binding)
# If running on cloud, set to public IP
# If running locally, leave blank for auto-detection
HOST_IP=

# =============================================================================
# Feature Toggle
# =============================================================================

# Enable phone integration (set to true to activate)
PHONE_ENABLED=false
