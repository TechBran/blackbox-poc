<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1A1A" />
            <corners android:radius="6dp" />
            <stroke android:width="1dp" android:color="#FF4444" />
            <padding android:left="6dp" android:right="20dp" android:top="2dp" android:bottom="2dp" />
        </shape>
    </item>
    <item android:gravity="end|center_vertical" android:right="6dp">
        <rotate
            android:fromDegrees="135"
            android:toDegrees="135"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape android:shape="rectangle">
                <size android:width="8dp" android:height="8dp" />
                <solid android:color="#FF4444" />
            </shape>
        </rotate>
    </item>
</layer-list>
