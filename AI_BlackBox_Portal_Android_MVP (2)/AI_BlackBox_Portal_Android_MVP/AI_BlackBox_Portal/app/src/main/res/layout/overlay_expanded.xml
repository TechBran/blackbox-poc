<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/expanded_panel_background"
    android:elevation="12dp">

    <!-- Top row: Drag handle + Status with symbol + Minimize -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="2dp">

        <!-- Drag handle (vertical bar) -->
        <View
            android:id="@+id/dragHandle"
            android:layout_width="4dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/drag_handle_background" />

        <!-- Status indicator (circle) -->
        <View
            android:id="@+id/statusIndicator"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/status_indicator_disconnected" />

        <!-- Status text -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Disconnected"
            android:textColor="#888888"
            android:textSize="12sp"
            android:singleLine="true" />

        <!-- Minimize button (arrow down) -->
        <ImageButton
            android:id="@+id/btnMinimize"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/arrow_down_float"
            android:background="@drawable/action_button_background"
            android:padding="6dp"
            android:contentDescription="Minimize"
            android:scaleType="fitCenter" />
    </LinearLayout>

    <!-- Second row: Model + Voice + Operator selectors -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingTop="2dp"
        android:paddingBottom="4dp">

        <!-- Model selector spinner (GPT Realtime / Gemini Live) -->
        <Spinner
            android:id="@+id/modelSpinner"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@drawable/spinner_background"
            android:paddingHorizontal="4dp"
            android:layout_marginEnd="4dp"
            android:dropDownWidth="140dp" />

        <!-- Voice selector spinner -->
        <Spinner
            android:id="@+id/voiceSpinner"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@drawable/spinner_background"
            android:paddingHorizontal="4dp"
            android:layout_marginEnd="4dp"
            android:dropDownWidth="120dp" />

        <!-- Operator selector spinner -->
        <Spinner
            android:id="@+id/operatorSpinner"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@drawable/spinner_background"
            android:paddingHorizontal="4dp"
            android:dropDownWidth="120dp" />
    </LinearLayout>

    <!-- Progress bar (for connection/processing) -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:visibility="gone"
        android:indeterminate="true"
        android:progressTint="#FF4444" />

    <!-- Action buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="8dp"
        android:paddingVertical="12dp"
        android:background="#111111">

        <!-- Screen Share button (Gemini Live only) -->
        <LinearLayout
            android:id="@+id/btnScreenShareContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="8dp"
            android:visibility="visible">

            <ImageButton
                android:id="@+id/btnScreenShare"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_share"
                android:background="@drawable/action_button_round"
                android:padding="10dp"
                android:contentDescription="Screen Share"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/screenShareLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Screen"
                android:textColor="#888888"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Camera button (opens native camera) -->
        <LinearLayout
            android:id="@+id/btnCameraContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="8dp"
            android:visibility="visible">

            <ImageButton
                android:id="@+id/btnCamera"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_camera"
                android:background="@drawable/action_button_round"
                android:padding="10dp"
                android:contentDescription="Camera"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Camera"
                android:textColor="#888888"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Mic button (primary action - larger) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="12dp">

            <ImageButton
                android:id="@+id/btnMic"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@android:drawable/ic_btn_speak_now"
                android:background="@drawable/mic_button_background"
                android:padding="12dp"
                android:contentDescription="Microphone"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/micLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to talk"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Connect/Disconnect button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="8dp">

            <ImageButton
                android:id="@+id/btnConnect"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_media_play"
                android:background="@drawable/action_button_round"
                android:padding="10dp"
                android:contentDescription="Connect"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/connectLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect"
                android:textColor="#888888"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Live response text (current AI utterance - auto-hides) -->
    <TextView
        android:id="@+id/liveResponseText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:text=""
        android:textColor="#CCCCCC"
        android:textSize="13sp"
        android:maxLines="3"
        android:ellipsize="end"
        android:visibility="gone" />

    <!-- Expandable Transcript Section -->
    <LinearLayout
        android:id="@+id/transcriptSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Transcript header with toggle -->
        <LinearLayout
            android:id="@+id/transcriptHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A1A1A"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Transcript"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/transcriptCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 messages"
                android:textColor="#666666"
                android:textSize="10sp"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/transcriptExpandIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/arrow_down_float"
                android:contentDescription="Expand transcript" />
        </LinearLayout>

        <!-- Transcript content (scrollable) -->
        <ScrollView
            android:id="@+id/transcriptScroll"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#0D0D0D"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/transcriptContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

    </LinearLayout>

    <!-- Bottom action bar (Full Portal only) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp"
        android:background="#0D0D0D">

        <!-- Open Portal button -->
        <LinearLayout
            android:id="@+id/btnPortalContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/action_button_background"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/btnPortal"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_view"
                android:scaleType="fitCenter"
                android:contentDescription="Portal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Portal"
                android:textColor="#FF4444"
                android:textSize="12sp"
                android:layout_marginStart="6dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Hidden elements for code compatibility (legacy references) -->
    <TextView
        android:id="@+id/responseText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/responseScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <EditText
        android:id="@+id/promptInput"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <ImageButton
        android:id="@+id/btnSend"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <View
        android:id="@+id/btnScreenshotContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <View
        android:id="@+id/btnRecordContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- TTS player legacy elements -->
    <TextView
        android:id="@+id/attachmentCount"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/ttsLabel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <HorizontalScrollView
        android:id="@+id/attachmentPreviewScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone">
        <LinearLayout
            android:id="@+id/attachmentPreviewContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/ttsPlayerBar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnTtsPlayPause"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <SeekBar
            android:id="@+id/ttsSeekBar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/ttsCurrentTime"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/ttsDuration"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnTtsStop"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnTts"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
