# ears.env - systemd EnvironmentFile for ugv-ears.service
# Copy to /home/jetson/ugv_ws_waveshare/ugv_tools_api/deploy/ears.env
# chmod 600 + chown root:root (same pattern as voice.env).
# Excluded from scripts/sync-ugv-tools.sh via --exclude 'deploy/ears.env'.
#
# NO API keys here - all STT/LLM calls route through BlackBox /stt + /chat.

BLACKBOX_URL=http://100.74.17.54:9091
BLACKBOX_OPERATOR=Brandon
BLACKBOX_MODEL=claude-sonnet-4-6
BLACKBOX_PROVIDER=anthropic

# Microphone substring match (pantilt camera's built-in USB Camera mic).
# Run `arecord -l` to identify; set to "" to use PyAudio default.
MIC_DEVICE_HINT=USB Camera

# openWakeWord
WAKEWORD_MODEL=/home/ws/ugv_ws/ugv_tools_api/voice_models/black_box_flight_recorder.onnx
WAKEWORD_THRESHOLD=0.5

# webrtcvad aggressiveness 0..3 (higher = more aggressive silence detection)
VAD_AGGRESSIVENESS=2

# Filesystem lock shared with ugv-voice to prevent self-trigger during TTS.
MUTE_FLAG_PATH=/tmp/ugv_ears_muted
