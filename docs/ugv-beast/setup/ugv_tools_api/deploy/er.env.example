# Gemini Robotics-ER 1.6 + OpenAI voice for UGV Beast
# Copy to er.env (0600 root:root) on the Jetson; never check in real values.
# Excluded from scripts/sync-ugv-tools.sh via --exclude 'deploy/er.env'.
#
# Shared EnvironmentFile for ugv-er, ugv-voice, and ugv-ears (systemd merges
# multiple EnvironmentFile= lines so all three services read from here).

# --- Vertex AI (Gemini Robotics-ER 1.6) -----------------------------------
# Service-account JSON path inside the container. The host file is deployed
# out-of-band via scp (0600 root:root) and bind-mounted into the container.
GOOGLE_APPLICATION_CREDENTIALS=/home/ws/ugv_ws/ugv_tools_api/credentials/gcp.json
# project_id field of the service-account JSON.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
ER_MODEL_ID=gemini-robotics-er-1.6-preview
# Hard cap on mission loop iterations; prevents runaway reasoning.
ER_MAX_STEPS=30
ER_PORT=8082

# --- OpenAI (Whisper STT + onyx-HD TTS) -----------------------------------
OPENAI_API_KEY=sk-...
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE=onyx
OPENAI_STT_MODEL=whisper-1

# --- Intra-Jetson service URLs --------------------------------------------
# All three services run in the same container network namespace.
TOOLS_API_URL=http://localhost:8080
SPEAK_URL=http://localhost:8081/speak
ER_URL=http://localhost:8082/mission
OPERATOR=Brandon
