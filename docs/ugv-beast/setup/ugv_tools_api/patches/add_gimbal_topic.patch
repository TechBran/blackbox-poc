+    # Callback for absolute gimbal position commands over /gimbal/absolute.
+    # Uses the firmware pan-tilt command (T=134), letting external clients (e.g.
+    # ugv_tools_api) command the gimbal directly in degrees without constructing a
+    # JointState message. This is the authoritative gimbal command path.
+    #   msg.x -> pan  (degrees, typically -180..180)
+    #   msg.y -> tilt (degrees, typically -45..90)
+    #   msg.z -> servo speed (1..2000; 0 falls back to 600 default)
+    def _on_gimbal_absolute(self, msg: Point):
+        pan_deg = float(msg.x)
+        tilt_deg = float(msg.y)
+        speed = int(msg.z) if msg.z else 600
+        cmd = json.dumps({
+            'T': 134,
+            'X': pan_deg,
+            'Y': tilt_deg,
+            'SX': speed,
+            'SY': speed,
         }) + "\n"
-                
-        ser.write(joint_data.encode())
+        ser.write(cmd.encode())
+        # Update the cached commanded pan/tilt so /gimbal/state reflects the latest target.
+        # Open-loop servos: this is our best estimate of "actual" position after settle.
+        self._last_gimbal_pan = pan_deg
+        self._last_gimbal_tilt = tilt_deg
+
+    # 10 Hz publisher for /gimbal/state. Republishes the cached last-commanded pan/tilt as a
+    # PointStamped so downstream tools (e.g. ugv_tools_api gimbal status) can read the current
+    # commanded position without subscribing to the full ESP32 telemetry stream. frame_id is
+    # 'pantilt_base' as a placeholder -- Waveshare's URDF doesn't define this frame, and we
+    # are not doing TF lookups against /gimbal/state today. Rename when URDF gains the frame.
+    def _publish_gimbal_state(self):
+        m = PointStamped()
+        m.header.stamp = self.get_clock().now().to_msg()
+        m.header.frame_id = 'pantilt_base'
+        m.point.x = self._last_gimbal_pan
+        m.point.y = self._last_gimbal_tilt
+        m.point.z = 0.0
+        self.gimbal_state_pub.publish(m)
+
+    # Callback for /ugv/json_cmd raw-JSON passthrough. msg.data is a JSON object
+    # string (e.g. '{"T": 0}'); we parse to validate, then re-serialize and write
+    # "<json>\n" to /dev/ttyTHS1. Used by ugv_tools_api system tools to issue
+    # ad-hoc firmware T-codes (emergency stop, servo center/release, ...) without
+    # adding a dedicated subscription per command. Parse errors are logged and
+    # the message is dropped so a malformed publisher cannot crash the driver.
+    def _on_json_cmd(self, msg: String):
+        try:
+            cmd = json.loads(msg.data)
+        except Exception as e:
+            self.get_logger().warn(f"/ugv/json_cmd parse error: {e!r} payload={msg.data!r}")
+            return
+        try:
+            ser.write((json.dumps(cmd) + "\n").encode())
+        except Exception as e:
+            self.get_logger().warn(f"/ugv/json_cmd serial write error: {e!r}")
 
