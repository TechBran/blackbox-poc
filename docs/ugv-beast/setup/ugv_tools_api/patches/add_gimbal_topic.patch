+        # (system tools, servo center, servo release, ...) without growing the driver
+        # surface every time a new command is needed. Malformed JSON is logged + dropped.
+        self.json_cmd_sub = self.create_subscription(String, '/ugv/json_cmd', self._on_json_cmd, 10)
